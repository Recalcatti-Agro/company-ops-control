# Branding overrides (optional; repo defaults to Recalcatti via config/branding.json)
COMPANY_NAME=Recalcatti
NEXT_PUBLIC_COMPANY_NAME=Recalcatti

# Django
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database runtime for app
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=replace-with-strong-password
DB_HOST=db
DB_PORT=5432

# PostgreSQL container bootstrap
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=replace-with-strong-password

# Public ports
WEB_PUBLIC_PORT=8000
FRONTEND_PUBLIC_PORT=3000
DB_PUBLIC_PORT=5432

# Frontend API
NEXT_PUBLIC_API_URL=http://localhost:8000/api
APP_DOMAIN=control.example.com

# Optional production backup upload
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=db-backups
